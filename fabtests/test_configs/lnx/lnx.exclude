# Regex patterns of tests to exclude in runfabtests.sh

# Unsupported EP types
^fi_msg
-e msg
^fi_dgram
-e dgram
cm_data

# Exclude tests with unsupported capabilities
atomic
scalable_ep
shared_ctx
multi_recv
cntr_pingpong
multi_ep
shared_av
-k
rma_event
rma_trigger
multi_mr
multinode

# Uses SOCKADDR
av_test

# Tests that are broken
recv_cancel
getinfo
inject_test -A
bw_mt